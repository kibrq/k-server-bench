SWEEP_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SWEEP_DIR}/../../../.." && pwd)"

SHINKA_WFA_LLM_MODELS=local-openai/gpt-oss-120b
SHINKA_WFA_META_LLM_MODELS=local-openai/gpt-oss-120b
SHINKA_WFA_NOVELTY_LLM_MODELS=local-openai/gpt-oss-120b
SHINKA_WFA_NUM_GENERATIONS=100
SHINKA_WFA_MAX_PARALLEL_JOBS=3
SHINKA_WFA_EVALUATE_PATH="${REPO_ROOT}/tools/evaluator/evaluate.py"

K_SERVER_EVALUATE_TIMEOUT=100
K_SERVER_EVALUATE_FINAL_EVALUATION_TIMEOUT=200
K_SERVER_EVALUATE_FINAL_EVALUATION_NUM_PROCESSES=1
K_SERVER_EVALUATE_N_CPUS=8
SHINKA_EXPERIMENT_PROMPT_PATH="${SWEEP_DIR}/PROMPT.md"
SHINKA_EXPERIMENT_SYSTEM_PATH="${SWEEP_DIR}/SYSTEM.md"
SHINKA_WFA_INITIAL_PATH="${SWEEP_DIR}/initial.py"
