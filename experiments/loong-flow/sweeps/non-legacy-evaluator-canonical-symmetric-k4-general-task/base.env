SWEEP_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SWEEP_DIR}/../../../.." && pwd)"

K_SERVER_EVAL_ENV=rl-k-servers
KSERVER_EVALUATE_SCRIPT="${REPO_ROOT}/tools/evaluator/evaluate.py"
K_SERVER_EVALUATE_TIMEOUT=600
K_SERVER_EVALUATE_FINAL_EVALUATION_TIMEOUT=200
K_SERVER_EVALUATE_FINAL_EVALUATION_NUM_PROCESSES=1
K_SERVER_EVALUATE_N_CPUS=8
