SWEEP_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SWEEP_DIR}/../../../.." && pwd)"

K_SERVER_EVALUATE_ASK_TELL_MEMORY_LIMIT=256
K_SERVER_EVALUATE_SEARCH_PROCESS_MEMORY_LIMIT=256
K_SERVER_EVALUATE_RAY_PORT=6379
K_SERVER_EVALUATE_SEARCH_TIMEOUT=600
K_SERVER_EVALUATE_SEARCH_MAX_CONCURRENT=10
K_SERVER_EVALUATE_SEARCH_MAX_WORKER_TIMEOUT=60
K_SERVER_EVALUATE_SEARCH_MIN_WORKER_TIMEOUT=10

K_SERVER_EVAL_ENV=rl-k-servers
KSERVER_EVALUATE_SCRIPT="${REPO_ROOT}/tools/legacy-evaluator/evaluate.py"
